{
  "name": "llm-provider-compat",
  "version": "0.2.0",
  "description": "Universal LLM provider compatibility layer — normalizes provider-specific payload differences (thinking formats, output budgets, tool pairing, media transport) into a single dispatch pipeline.",
  "license": "MIT",
  "author": "Guojiz <guojiz@proton.me>",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./dynamic-version": {
      "types": "./dist/dynamic-version.d.ts",
      "import": "./dist/dynamic-version.js",
      "require": "./dist/dynamic-version.cjs"
    }
  },
  "files": [
    "dist",
    "data",
    "LICENSE",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "npm run build"
  },
  "tsup": {
    "entry": {
      "index": "src/index.ts",
      "dynamic-version": "src/dynamic-version.ts"
    },
    "format": [
      "esm",
      "cjs"
    ],
    "dts": true,
    "splitting": false,
    "sourcemap": true,
    "clean": true
  },
  "devDependencies": {
    "@types/node": "^26.1.1",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "vitest": "^3.2.7"
  },
  "keywords": [
    "llm",
    "provider",
    "compat",
    "openai",
    "anthropic",
    "deepseek",
    "thinking",
    "reasoning",
    "payload",
    "normalize"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/Guojiz/llm-provider-compat"
  }
}
